# =============================================================================
# API Monitoring System — .gitignore
# =============================================================================

# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.yarn-integrity

# ─── Build Output ────────────────────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ─── Database & Cache ────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
data/
dump.rdb
*.rdb

# ─── Docker ──────────────────────────────────────────────────────────────────
# Keep docker-compose.yml but ignore local override files
docker-compose.override.yml
.docker/

# ─── OS & IDE ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Testing & Coverage ──────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
junit.xml

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.js.map
*.d.ts.map

# ─── Runtime / Temp ──────────────────────────────────────────────────────────
tmp/
temp/
.cache/
*.pid
*.seed
*.pid.lock
